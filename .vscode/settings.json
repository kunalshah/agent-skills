{
  "editor.minimap.enabled": false,
  "files.encoding": "utf8",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.autoSaveWhenNoErrors": true,
  "files.readonlyInclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/flutter/ephemeral": true,
    "**/Flutter/ephemeral": true,
    "**/.symlinks": true,
    "**/.plugin_symlinks": true,
    "**/node_modules/**": true,
    "**/pnpm-lock.yaml": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/bun.lock": true,
    "**/bun.lockb": true,
    "**/.svelte/**": true,
    "**/.svelte-kit/**": true,
    "**/.next/**": true,
    "**/dist/**": false,
    "**/build/**": false,
    "**/out/**": true,
    "**/output/**": true,
    "**/coverage/**": false,
    "**/uv.lock": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/.ruff_cache": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/*.pyd": true,
    "**/.pytest_cache": true,
    "**/*.egg-info": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/flutter/ephemeral": true,
    "**/Flutter/ephemeral": true,
    "**/.symlinks": true,
    "**/.plugin_symlinks": true,
    "**/node_modules/**": true,
    "**/pnpm-lock.yaml": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/bun.lock": true,
    "**/bun.lockb": true,
    "**/.svelte/**": true,
    "**/.svelte-kit/**": true,
    "**/.next/**": true,
    "**/dist/**": false,
    "**/build/**": false,
    "**/out/**": true,
    "**/output/**": true,
    "**/coverage/**": false,
    "**/uv.lock": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/.ruff_cache": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/*.pyd": true,
    "**/.pytest_cache": true,
    "**/*.egg-info": true
  },
  "explorer.excludeGitIgnore": false,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.sort.json": "never",
    "source.fixAll.biome": "always",
    "source.organizeImports.biome": "always",
    "source.removeUnusedImports": "never"
  },
  "editor.quickSuggestions": {
    "strings": "inline",
    "other": "inline",
    "comments": "inline"
  },
  "json.format.enable": true,
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.suggest.insertMode": "replace",
    "cSpell.fixSpellingWithRenameProvider": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.suggest.insertMode": "replace",
    "cSpell.fixSpellingWithRenameProvider": true
  },
  "cSpell.ignorePaths": [
    "**/.gitignore",
    "**/.vscode/settings.json",
    "**/pyproject.toml",
    "**/uv.lock",
    "**/package.json",
    "**/pnpm-lock.yaml",
    "**/yarn.lock",
    "**/bun.lock",
    "**/bun.lockb"
  ],
